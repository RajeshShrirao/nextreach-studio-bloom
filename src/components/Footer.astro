---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-zinc-800/60 mt-24 py-12 px-6 sm:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-10">
      <div class="col-span-2 sm:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-3 group" aria-label="NextReach Studio">
          <img src="/logo.png" alt="" width="24" height="24" class="opacity-80 group-hover:opacity-100 transition-opacity" />
          <span class="text-sm font-medium text-zinc-300 group-hover:text-white transition-colors">NextReach Studio</span>
        </a>
        <p class="text-xs text-zinc-500 leading-relaxed max-w-[180px]">
          Tools, guides, and resources for AI builders and indie hackers.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">Content</h3>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Blog</a></li>
          <li><a href="/guides" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Guides</a></li>
          <li><a href="/resources" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Resources</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">Tools</h3>
        <ul class="space-y-2">
          <li><a href="/tools/ai-token-calculator" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Token Calculator</a></li>
          <li><a href="/tools/context-window-calculator" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Context Window</a></li>
          <li><a href="/tools/llm-cost-calculator" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Cost Calculator</a></li>
          <li><a href="/tools/vram-estimator" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">VRAM Estimator</a></li>
          <li><a href="/tools/prompt-formatter" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Prompt Formatter</a></li>
          <li><a href="/tools" class="text-xs text-amber-500 hover:text-amber-300 transition-colors font-medium">All tools →</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">Site</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">About</a></li>
          <li><a href="/contact" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Contact</a></li>
          <li><a href="/privacy" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Terms &amp; Conditions</a></li>
          <li><a href="/rss.xml" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">RSS Feed</a></li>
          <li><a href="/sitemap-index.xml" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Sitemap</a></li>
        </ul>
      </div>
    </div>

    <div class="gradient-divider mb-6"></div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-zinc-600">&copy; {currentYear} NextReach Studio. All rights reserved.</p>
      <p class="text-xs text-zinc-600">Built for AI builders, indie hackers &amp; developers.</p>
    </div>
  </div>
</footer>
