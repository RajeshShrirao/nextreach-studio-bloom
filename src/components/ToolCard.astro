---
export interface Props {
  name: string;
  description: string;
  href: string;
  tags?: string[];
  badge?: string;
  icon?: string;
}

const { name, description, href, tags = [], badge, icon } = Astro.props;
---

<a
  href={href}
  class="card-premium-accent"
>
  <div class="flex items-start gap-4">
    {icon && (
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-zinc-800 text-amber-400 text-lg">
        {icon}
      </div>
    )}
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 mb-1.5">
        <h3 class="font-semibold text-white group-hover:text-amber-300 transition-colors text-sm leading-snug">
          {name}
        </h3>
        {badge && (
          <span class="badge-premium-accent">
            {badge}
          </span>
        )}
      </div>
      <p class="text-xs text-zinc-500 leading-relaxed line-clamp-2">{description}</p>
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="badge-premium-neutral">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 shrink-0 text-zinc-700 group-hover:text-amber-500 transition-colors">
      <path d="M9 18l6-6-6-6"/>
    </svg>
  </div>
</a>
