---
export interface Props {
  title: string;
  description: string;
  href: string;
  category?: string;
  tags?: string[];
  external?: boolean;
}

const { title, description, href, category, tags = [], external = false } = Astro.props;
---

<a
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  class="group flex flex-col rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-900/80 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/20"
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="min-w-0 flex-1">
      {category && (
        <p class="text-xs font-medium text-amber-500/80 uppercase tracking-wider mb-1">{category}</p>
      )}
      <h3 class="font-semibold text-white group-hover:text-amber-300 transition-colors text-sm leading-snug">
        {title}
      </h3>
    </div>
    {external ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 shrink-0 text-zinc-700 group-hover:text-zinc-400 transition-colors mt-0.5">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        <polyline points="15 3 21 3 21 9"/>
        <line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
    ) : (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 shrink-0 text-zinc-700 group-hover:text-amber-500 transition-colors mt-0.5">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    )}
  </div>
  <p class="text-xs text-zinc-500 leading-relaxed flex-1">{description}</p>
  {tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-xs text-zinc-500">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
