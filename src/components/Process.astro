---
const steps = [
  {
    number: "01",
    title: "Share your salon",
    description: "Tell us your services, breeds, pricing, hours. 10 min.",
    image: "https://images.unsplash.com/photo-1601758228041-f3b2795255f1?w=400&q=80",
  },
  {
    number: "02",
    title: "We build your AI",
    description: "Trained on your prices, services, and booking flow.",
    image: "https://images.unsplash.com/photo-1586671267731-da2cf3ceeb80?w=400&q=80",
  },
  {
    number: "03",
    title: "Go live & profit",
    description: "Live on your site. Answering questions, booking appointments.",
    image: "https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=400&q=80",
  },
];
---

<section class="max-w-7xl mx-auto px-6 sm:px-8 mb-40">
  <div class="text-center mb-20">
    <p class="text-xs uppercase tracking-[0.12em] text-zinc-500 mb-4">Process</p>
    <h2 class="font-display font-semibold text-4xl sm:text-5xl lg:text-6xl text-white tracking-[-0.01em] mb-6 leading-[1.2]">
      You didn&rsquo;t build this to manage a phone.
    </h2>
    <p class="text-zinc-400 max-w-xl mx-auto leading-[1.7] text-lg">
      You started because you&rsquo;re good at what you do. Every call you can&rsquo;t take
      is a business leaking money while you work. We built this so you can get back
      to the reason you started.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
    <div class="hidden md:block absolute top-[64px] left-[16%] right-[16%] h-px bg-gradient-to-r from-transparent via-zinc-700/50 to-transparent z-0" />
    <div class="hidden md:block absolute top-[64px] left-[33%] w-2 h-2 rounded-full bg-zinc-600/60 -translate-x-1/2 z-10" />
    <div class="hidden md:block absolute top-[64px] left-[66%] w-2 h-2 rounded-full bg-zinc-600/60 -translate-x-1/2 z-10" />

    {steps.map((step) => (
      <div class="glass-panel glass-panel-hover rounded-3xl relative overflow-hidden group">
        <div class="relative h-48 overflow-hidden">
          <img
            src={step.image}
            alt={step.title}
            width="400"
            height="200"
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-transparent to-black/80" />
          <div class="absolute top-4 left-4 w-10 h-10 rounded-full bg-black/40 backdrop-blur-md border border-white/[0.08] flex items-center justify-center text-xs text-amber-400 tracking-wide font-medium">
            {step.number}
          </div>
        </div>

        <div class="p-7">
          <h3 class="text-lg text-white mb-3 leading-[1.4]">{step.title}</h3>
          <p class="text-sm text-zinc-400 leading-[1.7]">{step.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
