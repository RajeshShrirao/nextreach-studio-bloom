---
import "../styles/globals.css";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: "website" | "article";
  pubDate?: Date;
  author?: string;
  tags?: string[];
}

const {
  title,
  description,
  image,
  canonicalURL,
  type = "website",
  pubDate,
  author = "NextReach Studio",
  tags = [],
} = Astro.props;

const siteURL = "https://www.nextreachstudio.com";
const siteTitle = title ? `${title} | NextReach Studio` : "NextReach Studio — Tools & Resources for AI Builders";
const siteDescription = description || "Practical tools, guides, and resources for AI builders, Claude Code users, indie hackers, and full-stack developers building with LLMs.";
const ogImage = image ? (image.startsWith("http") ? image : `${siteURL}${image}`) : `${siteURL}/link-previews.png`;
const canonical = canonicalURL || Astro.url.href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={canonical} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <link href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@400,500,700,800&display=swap" rel="stylesheet" media="all" />

    <!-- Icons -->
    <link rel="icon" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="NextReach Studio Blog" href="/rss.xml" />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-1DVFSD0J9Y"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1DVFSD0J9Y');
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="NextReach Studio" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Article-specific meta -->
    {type === "article" && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {type === "article" && author && (
      <meta property="article:author" content={author} />
    )}
    {type === "article" && tags.length > 0 && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta http-equiv="X-XSS-Protection" content="1; mode=block" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "NextReach Studio",
      "url": siteURL,
      "logo": `${siteURL}/logo.png`,
      "description": siteDescription,
    })} />

    <!-- Structured Data: Article (if article type) -->
    {type === "article" && pubDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": siteDescription,
        "image": ogImage,
        "author": {
          "@type": "Organization",
          "name": author,
        },
        "publisher": {
          "@type": "Organization",
          "name": "NextReach Studio",
          "url": siteURL,
        },
        "datePublished": pubDate.toISOString(),
        "url": canonical,
      })} />
    )}
  </head>
  <body class="font-body text-zinc-300 antialiased min-h-screen">
    <slot />
  </body>
</html>
