---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import Prose from "@/components/Prose.astro";
---

<Layout
  title="Contact Us"
  description="Contact NextReach Studio. Send feedback, report issues, suggest new tools, or ask questions about our AI developer tools and resources."
>
  <Nav />
  <main class="container-page relative">
    <div class="absolute top-0 left-1/4 -translate-y-12 w-[400px] h-[250px] bg-amber-400/5 rounded-full blur-[90px] pointer-events-none -z-10 animate-pulse-glow" aria-hidden="true"></div>

    <header class="header-page animate-fade-in-up">
      <p class="header-page-pretitle">Contact</p>
      <h1 class="header-page-title">Get in touch</h1>
      <p class="header-page-subtitle">
        Questions, feedback, tool ideas, or something broken? We'd love to hear from you.
      </p>
    </header>

    <div class="card-premium-flat mb-8">
      <form action="https://formspree.io/f/example" method="POST" class="space-y-5">
        <div>
          <label for="name" class="form-label-premium">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="form-input-premium"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="form-label-premium">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="form-input-premium"
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label for="subject" class="form-label-premium">Subject</label>
          <select
            id="subject"
            name="subject"
            class="form-select-premium"
          >
            <option value="" disabled selected>Select a topic</option>
            <option value="feedback">Feedback or suggestion</option>
            <option value="bug">Bug report</option>
            <option value="tool-idea">Tool idea</option>
            <option value="content">Content correction</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="message" class="form-label-premium">Message</label>
          <textarea
            id="message"
            name="message"
            rows={5}
            required
            class="form-textarea-premium"
            placeholder="What's on your mind?"
          ></textarea>
        </div>

        <button
          type="submit"
          class="btn-premium-primary"
        >
          Send message
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-4 h-4">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </form>
    </div>

    <Prose>
      <h2>Other ways to reach us</h2>
      <ul>
        <li><strong>Email:</strong> <a href="mailto:hello@nextreachstudio.com">hello@nextreachstudio.com</a></li>
        <li><strong>GitHub:</strong> <a href="https://github.com/sanruocc" target="_blank" rel="noopener noreferrer">github.com/sanruocc</a></li>
      </ul>

      <h2>Response time</h2>
      <p>
        We aim to respond to all inquiries within 48 hours during business days. For bug reports, we typically acknowledge within 24 hours.
      </p>
    </Prose>
  </main>
  <Footer />
</Layout>
