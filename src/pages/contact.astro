---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import Prose from "@/components/Prose.astro";
---

<Layout
  title="Contact Us"
  description="Contact NextReach Studio. Send feedback, report issues, suggest new tools, or ask questions about our AI developer tools and resources."
>
  <Nav />
  <main class="pt-28 pb-20 px-6 sm:px-8 max-w-3xl mx-auto">
    <header class="mb-12">
      <p class="text-xs uppercase tracking-[0.12em] text-zinc-600 mb-3">Contact</p>
      <h1 class="font-display font-semibold text-4xl sm:text-5xl text-white tracking-[-0.01em] mb-4">
        Get in touch
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed">
        Questions, feedback, tool ideas, or something broken? We'd love to hear from you.
      </p>
    </header>

    <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-8 mb-8">
      <form action="https://formspree.io/f/example" method="POST" class="space-y-5">
        <div>
          <label for="name" class="block text-sm text-zinc-400 mb-1.5 font-medium">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full rounded-lg border border-zinc-800 bg-zinc-900/60 px-4 py-2.5 text-sm text-white placeholder-zinc-600 outline-none transition-colors duration-200 focus:border-amber-700/50 focus:ring-1 focus:ring-amber-700/30"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block text-sm text-zinc-400 mb-1.5 font-medium">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full rounded-lg border border-zinc-800 bg-zinc-900/60 px-4 py-2.5 text-sm text-white placeholder-zinc-600 outline-none transition-colors duration-200 focus:border-amber-700/50 focus:ring-1 focus:ring-amber-700/30"
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label for="subject" class="block text-sm text-zinc-400 mb-1.5 font-medium">Subject</label>
          <select
            id="subject"
            name="subject"
            class="w-full rounded-lg border border-zinc-800 bg-zinc-900/60 px-4 py-2.5 text-sm text-white outline-none transition-colors duration-200 focus:border-amber-700/50 focus:ring-1 focus:ring-amber-700/30"
          >
            <option value="" disabled selected>Select a topic</option>
            <option value="feedback">Feedback or suggestion</option>
            <option value="bug">Bug report</option>
            <option value="tool-idea">Tool idea</option>
            <option value="content">Content correction</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm text-zinc-400 mb-1.5 font-medium">Message</label>
          <textarea
            id="message"
            name="message"
            rows={5}
            required
            class="w-full rounded-lg border border-zinc-800 bg-zinc-900/60 px-4 py-2.5 text-sm text-white placeholder-zinc-600 outline-none transition-colors duration-200 focus:border-amber-700/50 focus:ring-1 focus:ring-amber-700/30 resize-y min-h-[120px]"
            placeholder="What's on your mind?"
          ></textarea>
        </div>

        <button
          type="submit"
          class="btn-primary-glow inline-flex items-center gap-2 rounded-xl bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-all"
        >
          Send message
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-4 h-4">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </form>
    </div>

    <Prose>
      <h2>Other ways to reach us</h2>
      <ul>
        <li><strong>Email:</strong> <a href="mailto:hello@nextreachstudio.com">hello@nextreachstudio.com</a></li>
        <li><strong>GitHub:</strong> <a href="https://github.com/sanruocc" target="_blank" rel="noopener noreferrer">github.com/sanruocc</a></li>
      </ul>

      <h2>Response time</h2>
      <p>
        We aim to respond to all inquiries within 48 hours during business days. For bug reports, we typically acknowledge within 24 hours.
      </p>
    </Prose>
  </main>
  <Footer />
</Layout>
