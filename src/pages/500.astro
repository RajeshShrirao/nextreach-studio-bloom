---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
---

<Layout
  title="Server Error (500)"
  description="Something went wrong on our end. Please try again or browse our tools and resources."
>
  <Nav />
  <main class="pt-28 pb-20 px-6 sm:px-8 max-w-3xl mx-auto text-center">
    <p class="text-7xl sm:text-8xl font-display font-bold text-red-500/40 mb-4">500</p>
    <h1 class="font-display font-semibold text-3xl sm:text-4xl text-white mb-4">
      Something went wrong
    </h1>
    <p class="text-zinc-400 text-lg leading-relaxed mb-8 max-w-md mx-auto">
      An unexpected error occurred. We've been notified and are looking into it.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/" class="btn-primary-glow inline-flex items-center gap-2 rounded-xl bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-all">
        Go home
      </a>
      <a href="/contact" class="rounded-xl border border-zinc-800 px-6 py-3.5 text-sm text-zinc-400 hover:text-white hover:border-zinc-700 transition-all">
        Report issue
      </a>
    </div>
  </main>
  <Footer />
</Layout>
