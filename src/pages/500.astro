---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
---

<Layout
  title="Server Error (500)"
  description="Something went wrong on our end. Please try again or browse our tools and resources."
>
  <Nav />
  <main class="container-page relative text-center">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[280px] bg-red-500/5 rounded-full blur-[100px] pointer-events-none -z-10 animate-pulse-glow" aria-hidden="true"></div>

    <p class="text-7xl sm:text-8xl font-display font-extrabold text-transparent bg-clip-text bg-gradient-to-b from-red-500/40 to-transparent mb-4 leading-none select-none">500</p>
    <h1 class="font-display font-semibold text-3xl sm:text-4xl text-white mb-4">
      Something went wrong
    </h1>
    <p class="text-zinc-450 text-base sm:text-lg leading-relaxed mb-8 max-w-md mx-auto">
      An unexpected error occurred. We've been notified and are looking into it.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/" class="btn-premium-primary inline-flex items-center gap-2">
        Go home
      </a>
      <a href="/contact" class="btn-premium-secondary inline-flex items-center gap-2">
        Report issue
      </a>
    </div>
  </main>
  <Footer />
</Layout>
