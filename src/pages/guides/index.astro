---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";

const guides = await getCollection("guides", ({ data }) => !data.draft);
guides.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

---

<Layout
  title="Guides — In-Depth Tutorials for AI Developers"
  description="Practical, in-depth guides for AI builders. Covers LLM cost optimization, model selection, local AI setup, MCP, and developer workflows."
>
  <Nav />
  <main class="container-page">
    <header class="header-page animate-fade-in-up">
      <p class="header-page-pretitle">In-Depth Guides</p>
      <h1 class="header-page-title">Guides for AI builders</h1>
      <p class="header-page-subtitle">
        Long-form, practical guides. No buzzwords, no padding — just concrete techniques you can apply today.
      </p>
    </header>

    <div class="space-y-4 mb-16">
      {guides.length === 0 ? (
        <div class="card-premium-flat text-center">
          <p class="text-zinc-500 text-sm">Guides coming soon.</p>
        </div>
      ) : (
        guides.map((guide) => (
          <a
            href={`/guides/${guide.id}`}
            class="card-premium-interactive sm:p-6"
          >
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class={`rounded-full px-2 py-0.5 text-xs font-semibold capitalize border ${
                    guide.data.difficulty === "beginner"
                      ? "bg-emerald-500/10 text-emerald-400 border-emerald-500/20"
                      : guide.data.difficulty === "advanced"
                      ? "bg-red-500/10 text-red-400 border-red-500/20"
                      : "bg-blue-500/10 text-blue-400 border-blue-500/20"
                  }`}>
                    {guide.data.difficulty}
                  </span>
                  {guide.data.readingTime && (
                    <span class="text-xs text-zinc-500">{guide.data.readingTime}</span>
                  )}
                  <time datetime={guide.data.pubDate.toISOString()} class="text-xs text-zinc-500">
                    {guide.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                  </time>
                </div>
                <h2 class="font-display font-semibold text-white group-hover:text-amber-300 transition-colors text-xl sm:text-2xl leading-snug mb-2">
                  {guide.data.title}
                </h2>
                <p class="text-sm text-zinc-400 leading-relaxed mb-4">{guide.data.description}</p>
                {(guide.data.tags ?? []).length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {(guide.data.tags ?? []).slice(0, 4).map((tag) => (
                      <span class="badge-premium-neutral">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 shrink-0 text-zinc-700 group-hover:text-amber-500 transition-colors mt-1 hidden sm:block">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </div>
          </a>
        ))
      )}
    </div>
  </main>
  <Footer />
</Layout>
