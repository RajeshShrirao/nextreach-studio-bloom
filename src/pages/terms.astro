---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Terms of Service">
  <main class="min-h-screen px-4 py-20">
    <div class="max-w-3xl mx-auto">
      <div class="mb-12">
        <a href="/" class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors text-sm font-medium mb-8">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back to homepage
        </a>
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight">Terms of Service</h1>
        <p class="text-zinc-500 text-sm">Last updated: March 2026</p>
      </div>

      <div class="glass-panel rounded-2xl p-8">
        <div class="space-y-6">
          <section>
            <h2 class="text-lg font-semibold text-white mb-3">1. Agreement to Terms</h2>
            <p class="text-zinc-400 text-sm leading-relaxed">
              By accessing or using NextReach Studio&rsquo;s services, you agree to be bound by these
              Terms of Service and all applicable laws and regulations.
            </p>
          </section>
          <section>
            <h2 class="text-lg font-semibold text-white mb-3">2. Description of Service</h2>
            <p class="text-zinc-400 text-sm leading-relaxed">
              NextReach Studio provides AI-powered receptionist services for pet grooming salons
              and veterinary clinics, including a customizable chatbot that handles booking requests,
              answers customer questions, and captures leads on your website.
            </p>
          </section>
          <section>
            <h2 class="text-lg font-semibold text-white mb-3">3. Pricing &amp; Payment</h2>
            <p class="text-zinc-400 text-sm leading-relaxed">Pricing is as follows:</p>
            <ul class="text-zinc-400 text-sm leading-relaxed list-disc list-inside mt-2 space-y-1">
              <li><strong>Starter Plan:</strong> $299 one-time setup + $49/month</li>
              <li><strong>Pro Plan:</strong> $499 one-time setup + $79/month</li>
            </ul>
            <p class="text-zinc-400 text-sm leading-relaxed mt-3">
              Payment is due before your AI receptionist goes live. We accept payment via PayPal.
            </p>
          </section>
          <section>
            <h2 class="text-lg font-semibold text-white mb-3">4. Cancellation &amp; Refunds</h2>
            <p class="text-zinc-400 text-sm leading-relaxed">
              You may cancel your subscription at any time. Setup fees are non-refundable once we
              have begun building your demo. Monthly subscription fees are non-refundable.
            </p>
          </section>
          <section>
            <h2 class="text-lg font-semibold text-white mb-3">5. Your Responsibilities</h2>
            <p class="text-zinc-400 text-sm leading-relaxed">You are responsible for:</p>
            <ul class="text-zinc-400 text-sm leading-relaxed list-disc list-inside mt-2 space-y-1">
              <li>Providing accurate business information for your AI receptionist</li>
              <li>Keeping your account credentials secure</li>
              <li>Ensuring your use of the service complies with applicable laws</li>
            </ul>
          </section>
          <section>
            <h2 class="text-lg font-semibold text-white mb-3">6. Intellectual Property</h2>
            <p class="text-zinc-400 text-sm leading-relaxed">
              NextReach Studio and its original content, features, and functionality are owned by
              NextReach Studio. Your custom AI receptionist configuration remains your property.
            </p>
          </section>
          <section>
            <h2 class="text-lg font-semibold text-white mb-3">7. Limitation of Liability</h2>
            <p class="text-zinc-400 text-sm leading-relaxed">
              NextReach Studio shall not be liable for any indirect, incidental, special, consequential,
              or punitive damages resulting from your use or inability to use the service.
            </p>
          </section>
          <section>
            <h2 class="text-lg font-semibold text-white mb-3">8. Contact Us</h2>
            <p class="text-zinc-400 text-sm leading-relaxed">
              If you have any questions about these Terms, please contact us at <a href="mailto:hello@nextreachstudio.com" class="text-amber-400 hover:text-amber-300">hello@nextreachstudio.com</a>.
            </p>
          </section>
        </div>
      </div>
    </div>
  </main>
</Layout>
