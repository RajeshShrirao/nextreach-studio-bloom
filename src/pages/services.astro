---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Services">
  <main class="min-h-screen">
    <nav class="fixed w-full top-0 z-50 glass-panel border-b border-t-0 border-x-0">
      <div class="max-w-7xl mx-auto px-6 sm:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group -ml-2" aria-label="NextReach Studio - Home">
          <img src="/logo.png" alt="NextReach Studio" width="32" height="32" class="transition-transform duration-300 group-hover:scale-110" />
          <span class="text-white text-sm tracking-[0.08em] font-medium hidden sm:inline">NextReach Studio</span>
        </a>
        <div class="flex items-center gap-6">
          <a href="mailto:hello@nextreachstudio.com" class="text-zinc-500 text-xs hover:text-zinc-300 transition-colors duration-300 hidden sm:block">hello@nextreachstudio.com</a>
          <button onclick="window.dispatchEvent(new Event('open-chat-widget'))" class="text-sm font-bold bg-amber-400 text-black px-6 py-2.5 rounded-full tracking-[0.08em] uppercase hover:bg-amber-300 transition-all duration-300 hover:shadow-[0_0_28px_rgba(251,191,36,0.25)] min-h-[44px] flex items-center cursor-pointer">Free Demo</button>
        </div>
      </div>
    </nav>

    <div class="pt-32 px-6 sm:px-8 max-w-4xl mx-auto">
      <div class="text-center mb-20">
        <p class="text-xs uppercase tracking-[0.12em] text-zinc-500 mb-4">Services</p>
        <h1 class="font-display font-semibold text-4xl sm:text-5xl lg:text-6xl text-white tracking-[-0.01em] mb-6 leading-[1.2]">
          What we build
        </h1>
        <p class="text-zinc-400 max-w-2xl mx-auto leading-[1.7] text-lg">
          AI receptionists for pet grooming salons and vet clinics. We handle the calls so you can handle the clients.
        </p>
      </div>

      <div class="space-y-8 mb-40">
        <div class="glass-panel rounded-2xl p-8">
          <h2 class="text-2xl font-display font-semibold text-white mb-4">AI Receptionist</h2>
          <p class="text-zinc-400 leading-relaxed mb-6">
            A custom-trained AI that answers your salon&rsquo;s phone calls, chats with website visitors, and books appointments automatically. Trained on your services, breeds, pricing, and hours.
          </p>
          <ul class="space-y-3 text-sm text-zinc-400">
            <li class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5"><path d="M20 6L9 17l-5-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>24/7 call answering &mdash; never miss another booking</span>
            </li>
            <li class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5"><path d="M20 6L9 17l-5-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Breed &amp; service knowledge &mdash; answers client questions correctly</span>
            </li>
            <li class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5"><path d="M20 6L9 17l-5-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Website widget &mdash; embed on any site with one line of code</span>
            </li>
            <li class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5"><path d="M20 6L9 17l-5-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Booking capture &mdash; sends every detail straight to your inbox</span>
            </li>
          </ul>
        </div>

        <div class="glass-panel rounded-2xl p-8">
          <h2 class="text-2xl font-display font-semibold text-white mb-4">Lead Management</h2>
          <p class="text-zinc-400 leading-relaxed mb-6">
            A CRM dashboard that tracks every lead from first contact to booked appointment. See your pipeline, follow up automatically, and never lose a client again.
          </p>
          <ul class="space-y-3 text-sm text-zinc-400">
            <li class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5"><path d="M20 6L9 17l-5-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Automated follow-up emails &mdash; convert more leads</span>
            </li>
            <li class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5"><path d="M20 6L9 17l-5-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Pipeline tracking &mdash; know exactly where every lead stands</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </main>
</Layout>
