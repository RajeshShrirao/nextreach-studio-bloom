---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="We got your details!">
  <main class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="max-w-lg w-full text-center">
      <div class="mb-8 inline-flex items-center justify-center w-20 h-20 rounded-full bg-emerald-500/10 border border-emerald-500/20">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10 text-emerald-400"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight">
        We got your details!
      </h1>

      <p class="text-zinc-400 text-lg mb-8 leading-relaxed">
        Thanks for reaching out. We&rsquo;re reviewing your business info and
        will build a personalized AI receptionist demo just for you.
      </p>

      <div class="glass-panel rounded-2xl p-6 mb-6 text-left">
        <h2 class="text-amber-400 font-semibold text-xs uppercase tracking-widest mb-5">
          What happens next
        </h2>
        <div class="space-y-5">
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-lg bg-amber-400/10 flex items-center justify-center shrink-0">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-amber-400"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="text-white text-sm font-medium mb-1">Within 48 hours</p>
              <p class="text-zinc-400 text-sm">
                We build a custom demo tailored to your salon&rsquo;s services, breeds, and pricing.
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-lg bg-amber-400/10 flex items-center justify-center shrink-0">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-amber-400"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="text-white text-sm font-medium mb-1">Check your inbox</p>
              <p class="text-zinc-400 text-sm">
                You&rsquo;ll get an email with your demo link and next steps.
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-lg bg-amber-400/10 flex items-center justify-center shrink-0">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-amber-400"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <div>
              <p class="text-white text-sm font-medium mb-1">Approve &amp; go live</p>
              <p class="text-zinc-400 text-sm">
                Once you approve the demo, we&rsquo;ll send a PayPal invoice. No payment until you&rsquo;re happy.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-panel rounded-xl p-4 mb-8">
        <p class="text-zinc-400 text-sm">
          <span class="text-white font-medium">Payment:</span> PayPal invoice via email &mdash; no accounts to create, no apps to install.
        </p>
      </div>

      <a href="/" class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors text-sm font-medium">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to homepage
      </a>
    </div>
  </main>
</Layout>
