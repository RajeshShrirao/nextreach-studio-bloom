---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import ResourceCard from "@/components/ResourceCard.astro";
import { getCollection } from "astro:content";

const resources = await getCollection("resources", ({ data }) => !data.draft);
resources.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const categories = [...new Set(resources.map((r) => r.data.category))];
---

<Layout
  title="Resource Directory — LLM APIs, Tools, and Developer Stacks"
  description="Curated directories of LLM API providers, developer tools, frameworks, and resources for AI builders. Regularly updated with honest assessments."
>
  <Nav />
  <main class="container-page relative">
    <div class="absolute top-0 left-1/4 -translate-y-12 w-[400px] h-[250px] bg-amber-400/5 rounded-full blur-[90px] pointer-events-none -z-10 animate-pulse-glow" aria-hidden="true"></div>

    <header class="header-page animate-fade-in-up">
      <p class="header-page-pretitle">Resource Directory</p>
      <h1 class="header-page-title">Curated resources</h1>
      <p class="header-page-subtitle">
        Directories, comparisons, and reference lists for AI developers. Every entry is vetted — no affiliate links, no sponsored rankings.
      </p>
    </header>

    {categories.map((category) => (
      <section class="mb-12" aria-labelledby={`res-${category.toLowerCase().replace(/\s+/g, "-")}`}>
        <h2 id={`res-${category.toLowerCase().replace(/\s+/g, "-")}`} class="text-xs uppercase tracking-[0.12em] text-zinc-500 mb-4 font-semibold">
          {category}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {resources
            .filter((r) => r.data.category === category)
            .map((resource) => (
              <ResourceCard
                title={resource.data.title}
                description={resource.data.description}
                href={`/resources/${resource.id}`}
                tags={resource.data.tags.slice(0, 3)}
              />
            ))}
        </div>
      </section>
    ))}

    {resources.length === 0 && (
      <div class="card-premium-flat text-center">
        <p class="text-zinc-500 text-sm">Resources coming soon.</p>
      </div>
    )}
  </main>
  <Footer />
</Layout>
