---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Blog" description="Practical tutorials and insights for AI builders, Claude Code users, indie hackers, and developers working with LLMs.">
  <Nav />
  <main class="container-page">
    <header class="header-page animate-fade-in-up">
      <p class="header-page-pretitle">Blog</p>
      <h1 class="header-page-title">Tutorials &amp; insights</h1>
      <p class="header-page-subtitle">
        Practical articles for developers building with AI. No hype, no generic tips — just useful techniques for real workflows.
      </p>
    </header>

    <div class="space-y-4 mb-16">
      {posts.length === 0 && (
        <div class="card-premium-flat text-center">
          <p class="text-zinc-500">No posts yet. Check back soon.</p>
        </div>
      )}

      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="card-premium-interactive p-6 sm:p-8">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-3 text-xs text-zinc-500">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                </time>
                {post.data.tags.length > 0 && (
                  <>
                    <span>·</span>
                    <div class="flex gap-1.5 flex-wrap">
                      {post.data.tags.map((tag) => (
                        <span class="badge-premium-neutral">{tag}</span>
                      ))}
                    </div>
                  </>
                )}
              </div>
              <h2 class="text-xl sm:text-2xl font-display font-semibold text-white mb-3 group-hover:text-amber-300 transition-colors duration-300">
                {post.data.title}
              </h2>
              <p class="text-sm text-zinc-400 leading-relaxed">
                {post.data.description}
              </p>
            </div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 shrink-0 text-zinc-700 group-hover:text-amber-500 transition-colors mt-1 hidden sm:block">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Layout>
