---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

let allGuides: any[] = [];
try {
  const guides = await getCollection("guides", ({ data }) => !data.draft);
  allGuides = guides
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3);
} catch {}

const featuredTools = [
  {
    name: "AI Token Calculator",
    description: "Count tokens for any model before sending a prompt. Supports Claude, GPT-4, Llama, and 20+ other models.",
    href: "/tools/ai-token-calculator",
    icon: "⚡",
    badge: "Free",
  },
  {
    name: "LLM Cost Calculator",
    description: "Calculate the exact cost of your LLM API calls. Compare providers and find the cheapest option for your use case.",
    href: "/tools/llm-cost-calculator",
    icon: "💰",
    badge: "Free",
  },
  {
    name: "Context Window Calculator",
    description: "Visualize how much context you have left. Plan your prompts around token limits without guessing.",
    href: "/tools/context-window-calculator",
    icon: "📐",
    badge: "Free",
  },
  {
    name: "VRAM Estimator",
    description: "Estimate GPU memory requirements for running local LLMs. Know before you download if your GPU can handle it.",
    href: "/tools/vram-estimator",
    icon: "🖥️",
    badge: "Free",
  },
  {
    name: "Prompt Formatter",
    description: "Format, clean, and convert prompts between different model formats. Supports ChatML, Llama, Mistral, and more.",
    href: "/tools/prompt-formatter",
    icon: "✏️",
    badge: "Free",
  },
];
---

<Layout
  title="Tools & Resources for AI Builders"
  description="Practical tools, guides, and resources for AI builders, Claude Code users, indie hackers, and full-stack developers building with LLMs."
>
  <Nav />

  <main>
    <!-- Hero -->
    <section class="pt-36 pb-20 px-6 sm:px-8 max-w-5xl mx-auto">
      <div class="text-center">
        <p class="text-xs uppercase tracking-[0.15em] text-zinc-600 mb-5 font-medium">
          For AI builders, developers &amp; indie hackers
        </p>
        <h1 class="font-display font-semibold text-5xl sm:text-6xl lg:text-7xl text-white tracking-[-0.02em] leading-[1.1] mb-6">
          Build smarter with&nbsp;<br />
          <span class="text-amber-400">practical AI tools</span>
        </h1>
        <p class="text-zinc-400 text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto mb-10">
          Free calculators, honest guides, and no-fluff tutorials for developers
          working with Claude, Gemini, local LLMs, and MCP.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/tools"
            id="hero-tools-cta"
            class="btn-primary-glow inline-flex items-center gap-2 rounded-xl bg-amber-500 px-6 py-3 text-sm font-semibold text-zinc-950 transition-all"
          >
            Explore Tools
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a
            href="/guides"
            id="hero-guides-cta"
            class="inline-flex items-center gap-2 rounded-xl border border-zinc-700 px-6 py-3 text-sm font-medium text-zinc-300 hover:border-zinc-500 hover:text-white transition-all"
          >
            Read Guides
          </a>
        </div>
      </div>
    </section>

    <!-- Featured Tools -->
    <section class="py-16 px-6 sm:px-8 max-w-7xl mx-auto" id="tools" aria-labelledby="tools-heading">
      <div class="mb-10">
        <p class="text-xs uppercase tracking-[0.12em] text-zinc-600 mb-2">Developer Tools</p>
        <div class="flex items-end justify-between gap-4">
          <h2 id="tools-heading" class="font-display font-semibold text-3xl sm:text-4xl text-white tracking-[-0.01em]">
            Free AI calculators
          </h2>
          <a href="/tools" class="text-sm text-amber-500 hover:text-amber-400 transition-colors hidden sm:block shrink-0">
            All tools →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredTools.map((tool) => (
          <a
            href={tool.href}
            id={`tool-card-${tool.name.toLowerCase().replace(/\s+/g, "-")}`}
            class="group rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition-all duration-200 hover:border-amber-700/40 hover:bg-zinc-900/80 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/30"
          >
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-zinc-800 text-xl">
                {tool.icon}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-1.5">
                  <h3 class="font-semibold text-white group-hover:text-amber-300 transition-colors text-sm leading-snug">
                    {tool.name}
                  </h3>
                  <span class="shrink-0 rounded-full bg-emerald-500/10 px-2 py-0.5 text-xs font-medium text-emerald-400 border border-emerald-700/30">
                    {tool.badge}
                  </span>
                </div>
                <p class="text-xs text-zinc-500 leading-relaxed">{tool.description}</p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-6 text-center sm:hidden">
        <a href="/tools" class="text-sm text-amber-500 hover:text-amber-400 transition-colors">
          View all tools →
        </a>
      </div>
    </section>

    <!-- Latest Guides -->
    {allGuides.length > 0 && (
      <section class="py-16 px-6 sm:px-8 max-w-7xl mx-auto border-t border-zinc-800/60" id="guides" aria-labelledby="guides-heading">
        <div class="mb-10">
          <p class="text-xs uppercase tracking-[0.12em] text-zinc-600 mb-2">In-Depth Guides</p>
          <div class="flex items-end justify-between gap-4">
            <h2 id="guides-heading" class="font-display font-semibold text-3xl sm:text-4xl text-white tracking-[-0.01em]">
              Latest guides
            </h2>
            <a href="/guides" class="text-sm text-amber-500 hover:text-amber-400 transition-colors hidden sm:block shrink-0">
              All guides →
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {allGuides.map((guide) => (
            <a
              href={`/guides/${guide.slug}`}
              class="group rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-900/80 hover:-translate-y-0.5"
            >
              <div class="flex items-center gap-2 mb-3">
                <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-xs text-zinc-500 capitalize">
                  {guide.data.difficulty}
                </span>
                {guide.data.readingTime && (
                  <span class="text-xs text-zinc-600">{guide.data.readingTime}</span>
                )}
              </div>
              <h3 class="font-semibold text-white group-hover:text-amber-300 transition-colors text-sm leading-snug mb-2">
                {guide.data.title}
              </h3>
              <p class="text-xs text-zinc-500 leading-relaxed line-clamp-3">{guide.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Latest Blog Posts -->
    <section class="py-16 px-6 sm:px-8 max-w-7xl mx-auto border-t border-zinc-800/60" id="blog" aria-labelledby="blog-heading">
      <div class="mb-10">
        <p class="text-xs uppercase tracking-[0.12em] text-zinc-600 mb-2">From the Blog</p>
        <div class="flex items-end justify-between gap-4">
          <h2 id="blog-heading" class="font-display font-semibold text-3xl sm:text-4xl text-white tracking-[-0.01em]">
            Latest articles
          </h2>
          <a href="/blog" class="text-sm text-amber-500 hover:text-amber-400 transition-colors hidden sm:block shrink-0">
            All articles →
          </a>
        </div>
      </div>

      <div class="space-y-4">
        {latestPosts.length === 0 ? (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-8 text-center">
            <p class="text-zinc-500 text-sm">Articles coming soon.</p>
          </div>
        ) : (
          latestPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col sm:flex-row sm:items-start gap-4 rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-900/80 hover:-translate-y-0.5"
            >
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <time datetime={post.data.pubDate.toISOString()} class="text-xs text-zinc-600">
                    {post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                  </time>
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-xs text-zinc-500">{tag}</span>
                  ))}
                </div>
                <h3 class="font-semibold text-white group-hover:text-amber-300 transition-colors text-sm sm:text-base leading-snug mb-2">
                  {post.data.title}
                </h3>
                <p class="text-xs text-zinc-500 leading-relaxed line-clamp-2">{post.data.description}</p>
              </div>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 shrink-0 text-zinc-700 group-hover:text-amber-500 transition-colors mt-1 hidden sm:block">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </a>
          ))
        )}
      </div>

      <div class="mt-6 text-center sm:hidden">
        <a href="/blog" class="text-sm text-amber-500 hover:text-amber-400 transition-colors">
          All articles →
        </a>
      </div>
    </section>

    <!-- Resource Directory Teaser -->
    <section class="py-16 px-6 sm:px-8 max-w-7xl mx-auto border-t border-zinc-800/60" id="resources" aria-labelledby="resources-heading">
      <div class="mb-10">
        <p class="text-xs uppercase tracking-[0.12em] text-zinc-600 mb-2">Resource Directory</p>
        <div class="flex items-end justify-between gap-4">
          <h2 id="resources-heading" class="font-display font-semibold text-3xl sm:text-4xl text-white tracking-[-0.01em]">
            Curated resources
          </h2>
          <a href="/resources" class="text-sm text-amber-500 hover:text-amber-400 transition-colors hidden sm:block shrink-0">
            All resources →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/resources/llm-api-providers-directory" class="group rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-900/80 hover:-translate-y-0.5">
          <p class="text-xs font-medium text-amber-500/80 uppercase tracking-wider mb-2">API Providers</p>
          <h3 class="font-semibold text-white group-hover:text-amber-300 transition-colors text-sm leading-snug mb-2">
            LLM API Providers Directory
          </h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Every major LLM provider compared — pricing, rate limits, context windows, and ideal use cases.</p>
        </a>
        <a href="/resources/ai-developer-tools-stack" class="group rounded-xl border border-zinc-800 bg-zinc-900/40 p-5 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-900/80 hover:-translate-y-0.5">
          <p class="text-xs font-medium text-amber-500/80 uppercase tracking-wider mb-2">Developer Tools</p>
          <h3 class="font-semibold text-white group-hover:text-amber-300 transition-colors text-sm leading-snug mb-2">
            The AI Developer Tools Stack
          </h3>
          <p class="text-xs text-zinc-500 leading-relaxed">What serious AI builders actually use — curated tools, libraries, and services organized by category.</p>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
