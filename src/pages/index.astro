---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import ToolCard from "@/components/ToolCard.astro";
import ResourceCard from "@/components/ResourceCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

let allGuides: any[] = [];
try {
  const guides = await getCollection("guides", ({ data }) => !data.draft);
  allGuides = guides
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3);
} catch {}

const featuredTools = [
  {
    name: "AI Token Calculator",
    description: "Count tokens for any model before sending a prompt. Supports Claude, GPT-4, Llama, and 20+ other models.",
    href: "/tools/ai-token-calculator",
    icon: "⚡",
    badge: "Free",
  },
  {
    name: "LLM Cost Calculator",
    description: "Calculate the exact cost of your LLM API calls. Compare providers and find the cheapest option for your use case.",
    href: "/tools/llm-cost-calculator",
    icon: "💰",
    badge: "Free",
  },
  {
    name: "Context Window Calculator",
    description: "Visualize how much context you have left. Plan your prompts around token limits without guessing.",
    href: "/tools/context-window-calculator",
    icon: "📐",
    badge: "Free",
  },
  {
    name: "VRAM Estimator",
    description: "Estimate GPU memory requirements for running local LLMs. Know before you download if your GPU can handle it.",
    href: "/tools/vram-estimator",
    icon: "🖥️",
    badge: "Free",
  },
  {
    name: "Prompt Formatter",
    description: "Format, clean, and convert prompts between different model formats. Supports ChatML, Llama, Mistral, and more.",
    href: "/tools/prompt-formatter",
    icon: "✏️",
    badge: "Free",
  },
];
---

<Layout
  title="Tools & Resources for AI Builders"
  description="Practical tools, guides, and resources for AI builders, Claude Code users, indie hackers, and full-stack developers building with LLMs."
>
  <Nav />

  <main>
    <!-- Hero -->
    <section class="container-hero relative overflow-hidden">
      <!-- Ambient Spotlight Glow Overlay -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-12 w-[600px] h-[350px] bg-amber-400/10 rounded-full blur-[120px] pointer-events-none -z-10 animate-pulse-glow" aria-hidden="true"></div>

      <div class="text-center animate-fade-in-up relative z-10">
        <p class="text-xs uppercase tracking-[0.15em] text-amber-500/80 mb-5 font-semibold">
          For AI builders, developers &amp; indie hackers
        </p>
        <h1 class="text-hero text-white mb-6 font-display font-bold">
          Build smarter with&nbsp;<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-amber-400 to-yellow-500 glow-text">practical AI tools</span>
        </h1>
        <p class="text-zinc-400 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto mb-10 font-body">
          Free calculators, honest guides, and no-fluff tutorials for developers
          working with Claude, Gemini, local LLMs, and MCP.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/tools"
            id="hero-tools-cta"
            class="btn-premium-primary"
          >
            Explore Tools
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a
            href="/guides"
            id="hero-guides-cta"
            class="btn-premium-secondary"
          >
            Read Guides
          </a>
        </div>
      </div>
    </section>

    <!-- Featured Tools -->
    <section class="py-16 px-6 sm:px-8 max-w-7xl mx-auto" id="tools" aria-labelledby="tools-heading">
      <div class="mb-10">
        <p class="text-xs uppercase tracking-[0.12em] text-zinc-600 mb-2">Developer Tools</p>
        <div class="flex items-end justify-between gap-4">
          <h2 id="tools-heading" class="font-display font-semibold text-3xl sm:text-4xl text-white tracking-[-0.01em]">
            Free AI calculators
          </h2>
          <a href="/tools" class="text-sm text-amber-500 hover:text-amber-400 transition-colors hidden sm:block shrink-0">
            All tools →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredTools.map((tool) => (
          <ToolCard
            name={tool.name}
            description={tool.description}
            href={tool.href}
            icon={tool.icon}
            badge={tool.badge}
          />
        ))}
      </div>

      <div class="mt-6 text-center sm:hidden">
        <a href="/tools" class="text-sm text-amber-500 hover:text-amber-400 transition-colors">
          View all tools →
        </a>
      </div>
    </section>

    <!-- Latest Guides -->
    {allGuides.length > 0 && (
      <section class="py-16 px-6 sm:px-8 max-w-7xl mx-auto border-t border-zinc-800/60" id="guides" aria-labelledby="guides-heading">
        <div class="mb-10">
          <p class="text-xs uppercase tracking-[0.12em] text-zinc-600 mb-2">In-Depth Guides</p>
          <div class="flex items-end justify-between gap-4">
            <h2 id="guides-heading" class="font-display font-semibold text-3xl sm:text-4xl text-white tracking-[-0.01em]">
              Latest guides
            </h2>
            <a href="/guides" class="text-sm text-amber-500 hover:text-amber-400 transition-colors hidden sm:block shrink-0">
              All guides →
            </a>
          </div>
        </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {allGuides.map((guide) => (
          <a
            href={`/guides/${guide.id}`}
            class="card-premium-interactive group"
          >
            <div class="flex items-center gap-2 mb-3">
              <span class={`badge-premium-${guide.data.difficulty === 'beginner' ? 'beginner' : guide.data.difficulty === 'advanced' ? 'advanced' : 'intermediate'}`}>
                {guide.data.difficulty}
              </span>
              {guide.data.readingTime && (
                <span class="text-xs text-zinc-500 font-medium">{guide.data.readingTime}</span>
              )}
            </div>
            <h3 class="font-semibold text-white group-hover:text-amber-300 transition-colors text-sm leading-snug mb-2 font-display">
              {guide.data.title}
            </h3>
            <p class="text-xs text-zinc-400 leading-relaxed line-clamp-3 transition-colors group-hover:text-zinc-350">{guide.data.description}</p>
          </a>
        ))}
      </div>
      </section>
    )}

    <!-- Latest Blog Posts -->
    <section class="py-16 px-6 sm:px-8 max-w-7xl mx-auto border-t border-zinc-800/60" id="blog" aria-labelledby="blog-heading">
      <div class="mb-10">
        <p class="text-xs uppercase tracking-[0.12em] text-zinc-600 mb-2">From the Blog</p>
        <div class="flex items-end justify-between gap-4">
          <h2 id="blog-heading" class="font-display font-semibold text-3xl sm:text-4xl text-white tracking-[-0.01em]">
            Latest articles
          </h2>
          <a href="/blog" class="text-sm text-amber-500 hover:text-amber-400 transition-colors hidden sm:block shrink-0">
            All articles →
          </a>
        </div>
      </div>

      <div class="space-y-4">
        {latestPosts.length === 0 ? (
          <div class="card-premium-flat text-center">
            <p class="text-zinc-500 text-sm">Articles coming soon.</p>
          </div>
        ) : (
          latestPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="card-premium-interactive group flex flex-col sm:flex-row sm:items-start gap-4"
            >
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <time datetime={post.data.pubDate.toISOString()} class="text-xs text-zinc-500">
                    {post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                  </time>
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="badge-premium-neutral">{tag}</span>
                  ))}
                </div>
                <h3 class="font-semibold text-white group-hover:text-amber-300 transition-colors text-sm sm:text-base leading-snug mb-2 font-display">
                  {post.data.title}
                </h3>
                <p class="text-xs text-zinc-400 leading-relaxed line-clamp-2 transition-colors group-hover:text-zinc-300">{post.data.description}</p>
              </div>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 shrink-0 text-zinc-700 group-hover:text-amber-400 transition-all duration-300 group-hover:translate-x-1 mt-1 hidden sm:block">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </a>
          ))
        )}
      </div>

      <div class="mt-6 text-center sm:hidden">
        <a href="/blog" class="text-sm text-amber-500 hover:text-amber-400 transition-colors">
          All articles →
        </a>
      </div>
    </section>

    <!-- Resource Directory Teaser -->
    <section class="py-16 px-6 sm:px-8 max-w-7xl mx-auto border-t border-zinc-800/60" id="resources" aria-labelledby="resources-heading">
      <div class="mb-10">
        <p class="text-xs uppercase tracking-[0.12em] text-zinc-600 mb-2">Resource Directory</p>
        <div class="flex items-end justify-between gap-4">
          <h2 id="resources-heading" class="font-display font-semibold text-3xl sm:text-4xl text-white tracking-[-0.01em]">
            Curated resources
          </h2>
          <a href="/resources" class="text-sm text-amber-500 hover:text-amber-400 transition-colors hidden sm:block shrink-0">
            All resources →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <ResourceCard
          title="LLM API Providers Directory"
          description="Every major LLM provider compared — pricing, rate limits, context windows, and ideal use cases."
          href="/resources/llm-api-providers-directory"
          category="API Providers"
        />
        <ResourceCard
          title="The AI Developer Tools Stack"
          description="What serious AI builders actually use — curated tools, libraries, and services organized by category."
          href="/resources/ai-developer-tools-stack"
          category="Developer Tools"
        />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
