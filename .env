# ============================================
# NextReach Studio - Environment Configuration
# ============================================

# EmailJS Configuration (recommended for contact form)
# Get these from https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# Alternative: Zoho Mail SMTP Configuration
# Get these from https://www.zoho.com/mail/
ZOHO_EMAIL=your_zoho_email@domain.com
ZOHO_PASSWORD=your_zoho_app_password

# Contact form settings
VITE_CONTACT_EMAIL=admin@nextreachstudio.com
VITE_COMPANY_NAME=NextReach Studio

# Admin Dashboard Security
# IMPORTANT: Change this password for production!
VITE_ADMIN_PASSWORD=change_this_to_a_secure_password

# Environment mode
VITE_NODE_ENV=production

# Cerebras API for chatbot
